    <item>
      <title>Publications</title>
      <link>http://localhost:1313/publications/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/publications/</guid>
      <description>&lt;h2 id=&#34;full-publication-list&#34;&gt;Full publication list&lt;/h2&gt;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&lt;div&#xA;  class=&#34;scholar-feed&#34;&#xA;  data-user=&#34;all_publications&#34;&#xA;  data-limit=&#34;20&#34;&#xA;  data-sort=&#34;year_desc&#34;&#xA;  data-title=&#34;All Publications&#34;&#xA;&gt;&#xA;  &lt;div class=&#34;scholar-feed__state scholar-feed__state--loading&#34;&gt;&#xA;    Loading publications…&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function () {&#xA;  function escapeHtml(str) {&#xA;    return String(str ?? &#34;&#34;)&#xA;      .replace(/&amp;/g, &#34;&amp;amp;&#34;)&#xA;      .replace(/&lt;/g, &#34;&amp;lt;&#34;)&#xA;      .replace(/&gt;/g, &#34;&amp;gt;&#34;)&#xA;      .replace(/&#34;/g, &#34;&amp;quot;&#34;)&#xA;      .replace(/&#39;/g, &#34;&amp;#39;&#34;);&#xA;  }&#xA;&#xA;  function asNumber(value, fallback = 0) {&#xA;    const n = Number(value);&#xA;    return Number.isFinite(n) ? n : fallback;&#xA;  }&#xA;&#xA;  function sortPublications(pubs, sort) {&#xA;    const items = [...pubs];&#xA;    if (sort === &#34;cites_desc&#34;) {&#xA;      items.sort((a, b) =&gt; asNumber(b.cited_by) - asNumber(a.cited_by));&#xA;    } else if (sort === &#34;year_asc&#34;) {&#xA;      items.sort((a, b) =&gt; asNumber(a.year) - asNumber(b.year));&#xA;    } else {&#xA;      items.sort((a, b) =&gt; asNumber(b.year) - asNumber(a.year));&#xA;    }&#xA;    return items;&#xA;  }&#xA;&#xA;  function buildPublicationItem(p) {&#xA;    const title = escapeHtml(p.title || &#34;Untitled&#34;);&#xA;    const authors = escapeHtml(p.authors || &#34;&#34;);&#xA;    const venue = escapeHtml(p.venue || &#34;&#34;);&#xA;    const year = asNumber(p.year, 0);&#xA;    const citedBy = asNumber(p.cited_by, 0);&#xA;&#xA;    const titleHtml = p.url&#xA;      ? `&lt;a href=&#34;${p.url}&#34; target=&#34;_blank&#34; rel=&#34;noopener noreferrer&#34;&gt;${title}&lt;/a&gt;`&#xA;      : title;&#xA;&#xA;    return `&#xA;      &lt;li class=&#34;scholar-feed__item&#34;&gt;&#xA;        &lt;article class=&#34;scholar-feed__card&#34;&gt;&#xA;          &lt;h3 class=&#34;scholar-feed__paper-title&#34;&gt;&#xA;            ${titleHtml}&#xA;            ${year ? `&lt;span class=&#34;scholar-feed__year&#34;&gt;${year}&lt;/span&gt;` : &#34;&#34;}&#xA;          &lt;/h3&gt;&#xA;          &lt;div class=&#34;scholar-feed__meta&#34;&gt;&#xA;            ${authors ? `&lt;div class=&#34;scholar-feed__authors&#34;&gt;${authors}&lt;/div&gt;` : &#34;&#34;}&#xA;            ${venue ? `&lt;div class=&#34;scholar-feed__venue&#34;&gt;${venue}&lt;/div&gt;` : &#34;&#34;}&#xA;          &lt;/div&gt;&#xA;          &lt;div class=&#34;scholar-feed__links&#34;&gt;&#xA;            ${citedBy ? `&lt;span class=&#34;scholar-feed__badge&#34;&gt;Cited by ${citedBy}&lt;/span&gt;` : &#34;&#34;}&#xA;          &lt;/div&gt;&#xA;        &lt;/article&gt;&#xA;      &lt;/li&gt;&#xA;    `;&#xA;  }&#xA;&#xA;  function renderFeed(container, data) {&#xA;    const limit = asNumber(container.dataset.limit, 10);&#xA;    const sort = container.dataset.sort || &#34;year_desc&#34;;&#xA;    const blockTitle = container.dataset.title || &#34;All Publications&#34;;&#xA;&#xA;    let pubs = Array.isArray(data) ? data : (data.publications || []);&#xA;    pubs = sortPublications(pubs, sort).slice(0, limit);&#xA;&#xA;    const scholarProfile = data.profile_url&#xA;      ? `&lt;a class=&#34;scholar-feed__profile-link&#34; href=&#34;${data.profile_url}&#34; target=&#34;_blank&#34; rel=&#34;noopener noreferrer&#34;&gt;Google Scholar&lt;/a&gt;`&#xA;      : &#34;&#34;;&#xA;&#xA;    container.innerHTML = `&#xA;      &lt;section class=&#34;scholar-feed__wrapper&#34;&gt;&#xA;        &lt;div class=&#34;scholar-feed__header&#34;&gt;&#xA;          &lt;div&gt;&#xA;            &lt;h2 class=&#34;scholar-feed__title&#34;&gt;${escapeHtml(blockTitle)}&lt;/h2&gt;&#xA;            ${data.name ? `&lt;div class=&#34;scholar-feed__subtitle&#34;&gt;${escapeHtml(data.name)}&lt;/div&gt;` : &#34;&#34;}&#xA;          &lt;/div&gt;&#xA;          ${scholarProfile}&#xA;        &lt;/div&gt;&#xA;        &lt;ol class=&#34;scholar-feed__list&#34;&gt;&#xA;          ${pubs.map(buildPublicationItem).join(&#34;&#34;)}&#xA;        &lt;/ol&gt;&#xA;      &lt;/section&gt;&#xA;    `;&#xA;  }&#xA;&#xA;  function renderError(container, message) {&#xA;    container.innerHTML = `&lt;div class=&#34;scholar-feed__state scholar-feed__state--error&#34;&gt;${message}&lt;/div&gt;`;&#xA;  }&#xA;&#xA;  document.querySelectorAll(&#34;.scholar-feed&#34;).forEach((container) =&gt; {&#xA;    const user = container.dataset.user;&#xA;    const feedUrl = `/scholar/${encodeURIComponent(user)}.json`;&#xA;&#xA;    console.log(&#34;Scholar feed URL:&#34;, feedUrl);&#xA;&#xA;    fetch(feedUrl)&#xA;      .then((response) =&gt; {&#xA;        if (!response.ok) {&#xA;          throw new Error(`HTTP ${response.status} for ${feedUrl}`);&#xA;        }&#xA;        return response.json();&#xA;      })&#xA;      .then((data) =&gt; renderFeed(container, data))&#xA;      .catch((err) =&gt; {&#xA;        console.error(&#34;Scholar feed error:&#34;, err);&#xA;        renderError(container, &#34;Unable to load publications.&#34;);&#xA;      });&#xA;  });&#xA;})();&#xA;&lt;/script&gt;</description>
    </item>
